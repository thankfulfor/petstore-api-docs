@startuml
skinparam componentStyle rectangle
left to right direction

actor "Developer" as dev
rectangle "Petstore Platform" as platform {
  component "Petstore API\n(Pet / Store / Order)" as api
}
cloud "GitHub Pages\n(Documentation Hosting)" as pages
node "GitHub Actions\n(Build & Deploy)" as actions

dev --> api : Uses REST
actions --> pages : Deploys docs
dev --> pages : Reads docs portal
@enduml
